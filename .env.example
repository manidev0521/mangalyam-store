# ─────────────────────────────────────────────
#  Mangalyam Store — Environment Variables
# ─────────────────────────────────────────────

# MongoDB Connection String
# Local:   mongodb://localhost:27017/mangalyam
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/mangalyam
MONGODB_URI=mongodb://localhost:27017/mangalyam

# Server Port
PORT=5000

# JWT Secret (change this to a long random string in production!)
JWT_SECRET=mangalyam_g_anandan_secret_2025_change_this

# JWT Expiry
JWT_EXPIRES_IN=7d

# Node Environment: development | production
NODE_ENV=development

# Owner WhatsApp Number (for order notifications)
OWNER_PHONE=919710835979
